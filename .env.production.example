COMPOSE_PROJECT_NAME=dbf-comparator-pro
SERVER_NAME=_
APP_PORT=80
CLIENT_MAX_BODY_SIZE=100m

POSTGRES_DB=dbf_comparator
POSTGRES_USER=dbf_comparator
POSTGRES_PASSWORD=change_me_please

API_V1_PREFIX=/api/v1
APP_ENV=production
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://dbf_comparator:change_me_please@postgres:5432/dbf_comparator
REDIS_URL=redis://redis:6379/0
TEMP_STORAGE_ROOT=/tmp/dbf-comparator
UPLOAD_MAX_SIZE_BYTES=104857600
ARTIFACT_TTL_HOURS=24
CORS_ORIGINS=["http://SERVER_IP_OR_DOMAIN"]

